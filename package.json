    "@tokenring-ai/agent": "workspace:*",
    "@tokenring-ai/chat": "workspace:*",
    "@tokenring-ai/utility": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "vitest": "^4.1.1",
    "typescript": "^6.0.2"
  },
  "exports": {
