{
  "name": "@tokenring-ai/template",
  "version": "0.2.0",
  "description": "Template package for TokenRing Writer",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "test": "vitest run",
    "build": "tsc --noEmit",
